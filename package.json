{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node scripts/dev-local.mjs",
        "dev:assets": "vite",
        "dev:no-open": "node scripts/dev-local.mjs --no-open",
        "dev:restart": "node scripts/restart-local.mjs",
        "dev:stop": "node scripts/stop-local.mjs",
        "build": "vite build",
        "ai:server:start": "$HOME/.lmstudio/bin/lms server start --port 1234 --bind 127.0.0.1",
        "ai:server:stop": "$HOME/.lmstudio/bin/lms server stop",
        "db:migrate:local": "node scripts/dev-local.mjs --migrate-only",
        "infra:up": "node scripts/infra-up.mjs",
        "infra:down": "node scripts/infra-down.mjs",
        "infra:destroy": "node scripts/infra-destroy.mjs",
        "format": "npm run format:audit && npm run format:assets && npm run format:php",
        "format:audit": "node scripts/format-audit.mjs",
        "format:assets": "prettier . --write --ignore-unknown",
        "format:assets:check": "prettier . --check --ignore-unknown",
        "format:check": "npm run format:assets:check && npm run format:php:check",
        "format:php": "composer format",
        "format:php:check": "composer format:check",
        "lint": "npm run format:check",
        "lint:fix": "npm run format && composer lint",
        "quality": "npm run lint && npm run test:node && npm run security:ci && npm run build",
        "security:ci": "node scripts/check-ci-secrets.mjs",
        "test": "php artisan test",
        "test:all": "./run-all-tests.sh",
        "test:all:audit": "./run-all-tests.sh --with-audit",
        "test:node": "node --test tests/node/*.test.mjs"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.2.4",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
